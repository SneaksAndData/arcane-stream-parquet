    "targetTableFullName": "iceberg.test.parquet_test",
    "maintenanceSettings": {
      "targetOptimizeSettings": {
        "batchThreshold": 60,
        "fileSizeThreshold": "512MB"
      },
      "targetOrphanFilesExpirationSettings": {
        "batchThreshold": 60,
        "retentionThreshold": "6h"
      },
      "targetSnapshotExpirationSettings": {
        "batchThreshold": 60,
        "retentionThreshold": "6h"
      },
      "targetAnalyzeSettings": {
        "includedColumns": [],
        "batchThreshold": 60
      }
    },
    "icebergCatalog": {
      "catalogProperties": {},
      "catalogUri": "http://localhost:20001/catalog",
      "namespace": "test",
      "warehouse": "demo",
      "maxCatalogInstanceLifetime": "3600 second"
    }
